{
	"compatibility_date": "2026-04-28",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "form_submission_viewer",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "local"
		}
	]
}

---
import BaseLayout from "../layouts/BaseLayout.astro";

const token = Astro.locals.access_token;

const fetchSites = async () => {
    const req = await fetch('https://api.webflow.com/v2/sites', {
        headers: { 'Authorization': `Bearer ${token}` },
    });
    if (!req.ok) return [];
    const json = await req.json();
    return json.sites || [];
};

const sites = await fetchSites();

if (sites.length === 0) {
    // Nothing to show — bounce to a friendly empty state on the index.
    // Easier than rendering a one-off empty dashboard.
    await Astro.session?.set('error', 'no_sites_available');
    return Astro.redirect('/');
}

const requestedSiteId = Astro.url.searchParams.get('siteId');
const activeSite = sites.find((s) => s.id === requestedSiteId) || sites[0];

const SITE_ID = activeSite.id;
const SITE_NAME = activeSite.displayName;
---

<BaseLayout pageTitle={`Submissions · ${SITE_NAME}`}>

    <main class="page">

        <div class="dash-header">
            <div class="dash-title">
                <h1>Form submissions</h1>

                <div class="dash-filters">
                    <div class="site-switcher" id="siteSwitcher">
                        <button class="site-switcher-btn" id="siteSwitcherBtn" aria-haspopup="listbox" aria-expanded="false">
                            <span class="site-avatar site-avatar-sm">{(SITE_NAME || '?').charAt(0).toUpperCase()}</span>
                            <span class="site-switcher-name">{SITE_NAME}</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="site-switcher-chev"><polyline points="6 9 12 15 18 9"/></svg>
                        </button>
                        <ul class="site-switcher-menu" id="siteSwitcherMenu" role="listbox">
                            {sites.map((site) => (
                                <li>
                                    <a
                                        href={`/dashboard?siteId=${site.id}`}
                                        class={`site-switcher-item ${site.id === SITE_ID ? 'active' : ''}`}
                                        role="option"
                                        aria-selected={site.id === SITE_ID}
                                    >
                                        <span class="site-avatar site-avatar-sm">{(site.displayName || '?').charAt(0).toUpperCase()}</span>
                                        <span class="site-switcher-name">{site.displayName}</span>
                                        {site.id === SITE_ID && (
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="site-switcher-check"><polyline points="20 6 9 17 4 12"/></svg>
                                        )}
                                    </a>
                                </li>
                            ))}
                            <li class="site-switcher-sep"></li>
                            <li>
                                <a href="/logout" class="site-switcher-item site-switcher-logout">Sign out</a>
                            </li>
                        </ul>
                    </div>

                    <div class="site-switcher form-filter" id="formFilter" hidden>
                        <button class="site-switcher-btn" id="formFilterBtn" aria-haspopup="listbox" aria-expanded="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="form-filter-icon"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                            <span class="site-switcher-name" id="formFilterLabel">All forms</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="site-switcher-chev"><polyline points="6 9 12 15 18 9"/></svg>
                        </button>
                        <ul class="site-switcher-menu" id="formFilterMenu" role="listbox"></ul>
                    </div>
                </div>
            </div>
            <div class="dash-actions">
                <div class="search">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="7"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="search" id="searchInput" placeholder="Search submissions..." />
                </div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <span class="panel-title">All submissions</span>
                <span class="panel-count" id="panelCount"><span class="spinner"></span> Loading…</span>
            </div>

            <div id="tableHost">
                <div class="empty">
                    <div class="empty-title">Fetching submissions…</div>
                </div>
            </div>
        </div>

    </main>

    <!-- Confirm delete modal -->
    <div class="modal-backdrop" id="confirmModal" role="dialog" aria-modal="true">
        <div class="modal">
            <h3>Delete this submission?</h3>
            <p>This permanently removes the submission from Webflow. This action can't be undone.</p>
            <div class="modal-actions">
                <button class="btn btn-ghost" id="confirmCancel">Cancel</button>
                <button class="btn btn-danger" id="confirmDelete">Delete</button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast"></div>

</BaseLayout>

<script define:vars={{ SITE_ID }}>
    let SUBMISSIONS = [];
    const expanded = new Set();
    let pendingDelete = null;
    let searchTerm = '';
    let activeFormFilter = 'all';

    const $ = (sel) => document.querySelector(sel);
    const tableHost = $('#tableHost');
    const panelCount = $('#panelCount');
    const modal = $('#confirmModal');
    const toastEl = $('#toast');

    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function formatDate(iso) {
        if (!iso) return '—';
        try {
            const d = new Date(iso);
            return d.toLocaleString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        } catch { return iso; }
    }

    function humanizeKey(k) {
        return String(k)
            .replace(/[-_]+/g, ' ')
            .replace(/([a-z])([A-Z])/g, '$1 $2')
            .replace(/\s+/g, ' ')
            .trim()
            .replace(/^\w/, (c) => c.toUpperCase());
    }

    function isUrl(v) {
        if (typeof v !== 'string') return false;
        return /^https?:\/\/\S+$/i.test(v.trim());
    }

    function isEmail(v) {
        return typeof v === 'string' && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
    }

    function renderValue(v) {
        if (v === null || v === undefined || v === '') {
            return '<span class="kv-val empty">empty</span>';
        }
        if (typeof v === 'boolean') {
            return `<div class="kv-val">${v ? 'Yes' : 'No'}</div>`;
        }
        if (typeof v === 'number') {
            return `<div class="kv-val">${v}</div>`;
        }
        if (Array.isArray(v)) {
            if (v.length === 0) return '<span class="kv-val empty">empty</span>';
            return `<div class="kv-val">${v.map((x) => escapeHtml(typeof x === 'object' ? JSON.stringify(x) : String(x))).join(', ')}</div>`;
        }
        if (typeof v === 'object') {
            return `<div class="kv-val"><pre>${escapeHtml(JSON.stringify(v, null, 2))}</pre></div>`;
        }
        const s = String(v);
        if (isUrl(s)) {
            return `<div class="kv-val"><a href="${escapeHtml(s)}" target="_blank" rel="noopener noreferrer">${escapeHtml(s)}</a></div>`;
        }
        if (isEmail(s)) {
            return `<div class="kv-val"><a href="mailto:${escapeHtml(s)}">${escapeHtml(s)}</a></div>`;
        }
        if (s.length > 200 || s.includes('\n')) {
            return `<div class="kv-val"><pre>${escapeHtml(s)}</pre></div>`;
        }
        return `<div class="kv-val">${escapeHtml(s)}</div>`;
    }

    function getFormName(sub) {
        return sub.displayName
            || sub.formResponse?.formName
            || sub.formResponse?.name
            || sub.formName
            || sub.name
            || 'Untitled form';
    }

    function getFormData(sub) {
        return sub.formResponse || sub.data || sub.payload || {};
    }

    function getSubmittedAt(sub) {
        return sub.dateSubmitted || sub.submittedAt || sub.createdOn || sub.dateCreated || '';
    }

    function filtered() {
        const q = searchTerm.toLowerCase();
        return SUBMISSIONS.filter((s) => {
            if (activeFormFilter !== 'all' && getFormName(s) !== activeFormFilter) return false;
            if (!q) return true;
            if (getFormName(s).toLowerCase().includes(q)) return true;
            const data = getFormData(s);
            for (const k of Object.keys(data)) {
                if (k.toLowerCase().includes(q)) return true;
                const v = data[k];
                if (typeof v === 'string' && v.toLowerCase().includes(q)) return true;
            }
            return false;
        });
    }

    function render() {
        const rows = filtered();
        panelCount.textContent = `${rows.length} of ${SUBMISSIONS.length}`;

        if (SUBMISSIONS.length === 0) {
            tableHost.innerHTML = `
                <div class="empty">
                    <div class="empty-title">No form submissions yet</div>
                    <div class="empty-sub">When someone submits a form on this site, it'll appear here.</div>
                </div>`;
            return;
        }
        if (rows.length === 0) {
            tableHost.innerHTML = `
                <div class="empty">
                    <div class="empty-title">No matches</div>
                    <div class="empty-sub">Try a different search term.</div>
                </div>`;
            return;
        }

        const body = rows.map((sub) => {
            const id = sub.id || sub._id;
            const isOpen = expanded.has(id);
            const formName = escapeHtml(getFormName(sub));
            const submittedAt = escapeHtml(formatDate(getSubmittedAt(sub)));
            const data = getFormData(sub);
            const entries = Object.entries(data);

            const detail = isOpen ? `
                <tr class="detail-row">
                    <td colspan="4">
                        <div class="detail-wrap">
                            <div class="detail-meta">
                                <div><strong>ID:</strong>${escapeHtml(id || '')}</div>
                                <div><strong>Submitted:</strong>${submittedAt}</div>
                                ${sub.formId ? `<div><strong>Form ID:</strong>${escapeHtml(sub.formId)}</div>` : ''}
                            </div>
                            ${entries.length === 0
                                ? `<div class="empty-sub">This submission has no field data.</div>`
                                : `<div class="kv-grid">${entries.map(([k, v]) => `
                                    <div class="kv-key">${escapeHtml(humanizeKey(k))}</div>
                                    ${renderValue(v)}
                                `).join('')}</div>`
                            }
                        </div>
                    </td>
                </tr>` : '';

            return `
                <tr class="row ${isOpen ? 'expanded' : ''}" data-id="${escapeHtml(id || '')}">
                    <td class="col-caret">
                        <svg class="caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </td>
                    <td>
                        <div class="form-name"><span class="form-name-dot"></span>${formName}</div>
                    </td>
                    <td class="col-date">${submittedAt}</td>
                    <td class="col-actions">
                        <button class="icon-btn delete-btn" data-id="${escapeHtml(id || '')}" aria-label="Delete submission" title="Delete">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                <path d="M10 11v6M14 11v6"/>
                                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                            </svg>
                        </button>
                    </td>
                </tr>
                ${detail}
            `;
        }).join('');

        tableHost.innerHTML = `
            <table class="subs-table">
                <thead>
                    <tr>
                        <th class="col-caret"></th>
                        <th>Form</th>
                        <th class="col-date">Submitted</th>
                        <th class="col-actions"></th>
                    </tr>
                </thead>
                <tbody>${body}</tbody>
            </table>
        `;
    }

    function showToast(message, isError = false) {
        toastEl.textContent = message;
        toastEl.classList.toggle('error', isError);
        toastEl.classList.add('show');
        setTimeout(() => toastEl.classList.remove('show'), 2400);
    }

    function openConfirm(id) {
        pendingDelete = id;
        modal.classList.add('open');
    }
    function closeConfirm() {
        pendingDelete = null;
        modal.classList.remove('open');
    }

    async function doDelete() {
        if (!pendingDelete) return;
        const id = pendingDelete;
        const btn = document.getElementById('confirmDelete');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>';
        try {
            const res = await fetch(`/api/submissions/${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                throw new Error(err.error || `HTTP ${res.status}`);
            }
            SUBMISSIONS = SUBMISSIONS.filter((s) => (s.id || s._id) !== id);
            expanded.delete(id);
            showToast('Submission deleted');
            buildFormFilterMenu();
            render();
        } catch (e) {
            showToast(`Failed to delete: ${e.message}`, true);
        } finally {
            btn.disabled = false;
            btn.textContent = 'Delete';
            closeConfirm();
        }
    }

    tableHost.addEventListener('click', (e) => {
        const delBtn = e.target.closest('.delete-btn');
        if (delBtn) {
            e.stopPropagation();
            openConfirm(delBtn.dataset.id);
            return;
        }
        const row = e.target.closest('tr.row');
        if (row) {
            const id = row.dataset.id;
            if (expanded.has(id)) expanded.delete(id);
            else expanded.add(id);
            render();
        }
    });

    document.getElementById('confirmCancel').addEventListener('click', closeConfirm);
    document.getElementById('confirmDelete').addEventListener('click', doDelete);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeConfirm(); });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('open')) closeConfirm();
    });

    document.getElementById('searchInput').addEventListener('input', (e) => {
        searchTerm = e.target.value.trim();
        render();
    });

    // Generic dropdown wiring — used for both the site switcher and form filter.
    const dropdowns = [
        { root: document.getElementById('siteSwitcher'), btn: document.getElementById('siteSwitcherBtn') },
        { root: document.getElementById('formFilter'), btn: document.getElementById('formFilterBtn') },
    ];

    dropdowns.forEach(({ root, btn }) => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            // Close all other dropdowns first
            dropdowns.forEach((d) => {
                if (d.root !== root) {
                    d.root.classList.remove('open');
                    d.btn.setAttribute('aria-expanded', 'false');
                }
            });
            const open = root.classList.toggle('open');
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
    });

    document.addEventListener('click', (e) => {
        dropdowns.forEach(({ root, btn }) => {
            if (!root.contains(e.target)) {
                root.classList.remove('open');
                btn.setAttribute('aria-expanded', 'false');
            }
        });
    });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            dropdowns.forEach(({ root, btn }) => {
                root.classList.remove('open');
                btn.setAttribute('aria-expanded', 'false');
            });
        }
    });

    // Form filter — populated after submissions load.
    const formFilter = document.getElementById('formFilter');
    const formFilterBtn = document.getElementById('formFilterBtn');
    const formFilterMenu = document.getElementById('formFilterMenu');
    const formFilterLabel = document.getElementById('formFilterLabel');

    function buildFormFilterMenu() {
        const names = Array.from(new Set(SUBMISSIONS.map(getFormName))).sort((a, b) =>
            a.localeCompare(b, undefined, { sensitivity: 'base' })
        );

        // If the current filter is no longer present (e.g. after switching sites in a future
        // change), reset to "all".
        if (activeFormFilter !== 'all' && !names.includes(activeFormFilter)) {
            activeFormFilter = 'all';
        }

        const options = [{ value: 'all', label: 'All forms', count: SUBMISSIONS.length }]
            .concat(names.map((n) => ({
                value: n,
                label: n,
                count: SUBMISSIONS.filter((s) => getFormName(s) === n).length,
            })));

        formFilterMenu.innerHTML = options.map((opt) => `
            <li>
                <button
                    type="button"
                    class="site-switcher-item form-filter-item ${opt.value === activeFormFilter ? 'active' : ''}"
                    data-value="${escapeHtml(opt.value)}"
                    role="option"
                    aria-selected="${opt.value === activeFormFilter}"
                >
                    <span class="site-switcher-name">${escapeHtml(opt.label)}</span>
                    <span class="form-filter-count">${opt.count}</span>
                    ${opt.value === activeFormFilter
                        ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="site-switcher-check"><polyline points="20 6 9 17 4 12"/></svg>'
                        : ''}
                </button>
            </li>
        `).join('');

        formFilterLabel.textContent = activeFormFilter === 'all' ? 'All forms' : activeFormFilter;
        formFilter.hidden = false;
    }

    formFilterMenu.addEventListener('click', (e) => {
        const item = e.target.closest('.form-filter-item');
        if (!item) return;
        activeFormFilter = item.dataset.value;
        formFilter.classList.remove('open');
        formFilterBtn.setAttribute('aria-expanded', 'false');
        buildFormFilterMenu();
        render();
    });

    async function load() {
        try {
            const res = await fetch(`/api/submissions.json?siteId=${encodeURIComponent(SITE_ID)}`);
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                throw new Error(err.error || `HTTP ${res.status}`);
            }
            const json = await res.json();
            SUBMISSIONS = (json.submissions || []).sort((a, b) => {
                const da = new Date(getSubmittedAt(a)).getTime() || 0;
                const db = new Date(getSubmittedAt(b)).getTime() || 0;
                return db - da;
            });
            buildFormFilterMenu();
            render();
        } catch (e) {
            tableHost.innerHTML = `
                <div class="empty">
                    <div class="empty-title" style="color: var(--danger);">Couldn't load submissions</div>
                    <div class="empty-sub">${escapeHtml(e.message)}</div>
                </div>`;
            panelCount.textContent = '';
        }
    }

    load();
</script>
